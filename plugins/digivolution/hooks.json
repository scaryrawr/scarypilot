{
  "version": 1,
  "hooks": {
    "userPromptSubmitted": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/hooks/digivolution.mjs\" mark",
        "timeoutSec": 5
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/hooks/digivolution.mjs\" reflect",
        "timeoutSec": 5
      }
    ]
  }
}
